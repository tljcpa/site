---
import { getAllProjects } from "@/data/project";
import PageLayout from "@/layouts/Base.astro";

const projects = await getAllProjects(); // 已按 weight 降序

// 按类型分组,顺序即重要性。组内保持 weight 序。
const groups = [
	{ kind: "实习", label: "实习项目", note: "真实企业实习,工程链路最完整——这是我最能打的。" },
	{ kind: "比赛", label: "竞赛作品", note: "七牛云、智联等比赛里做的东西。" },
	{ kind: "面试作品", label: "面试项目", note: "面试中独立完成的作品,公司与题目已脱敏,保留技术方案。" },
	{ kind: "开源复现", label: "开源复现", note: "复现前沿工作,验证技术路线、踩透框架坑。" },
	{ kind: "个人", label: "个人项目", note: "自己起意做的工具,从零跑起来。" },
	{ kind: "学习", label: "学习记录", note: "边学边做的过程,诚实包含没做完的。" },
];

const grouped = groups
	.map((g) => ({ ...g, items: projects.filter((p) => p.data.kind === g.kind) }))
	.filter((g) => g.items.length > 0);

const meta = {
	title: "项目",
	description: "我做过的项目——按类型分组:实习、竞赛、面试作品、开源复现、个人、学习。",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-2">项目</h1>
	<p class="text-muted mb-10 text-sm">
		近三个月的活儿,按类型分组、从最有分量的排起。每个卡片点进去是这个项目怎么从零跑起来、踩过哪些坑的复盘。
	</p>

	{
		grouped.map((g) => (
			<section class="mb-12">
				<div class="mb-1 flex items-center gap-2">
					<h2 class="title text-lg">{g.label}</h2>
					{g.kind === "实习" && (
						<span class="bg-accent/15 text-accent rounded px-2 py-0.5 text-xs font-semibold">
							旗舰
						</span>
					)}
					<span class="text-muted text-xs">{g.items.length}</span>
				</div>
				<p class="text-muted mb-5 text-xs">{g.note}</p>
				<ul class="grid grid-cols-1 gap-5 sm:grid-cols-2" role="list">
					{g.items.map((project) => (
						<li
							class:list={[
								"flex flex-col rounded-md border p-5 transition-colors",
								project.data.flagship
									? "border-accent/40 hover:border-accent sm:col-span-2"
									: "border-muted/40 hover:border-accent",
							]}
						>
							<div class="mb-2 flex items-center justify-between gap-2">
								<a
									href={`/projects/${project.id}/`}
									class="text-accent text-lg font-semibold hover:underline"
								>
									{project.data.title}
								</a>
								{project.data.period && (
									<span class="text-muted shrink-0 text-xs">{project.data.period}</span>
								)}
							</div>
							<p class="text-muted mb-3 grow text-sm">{project.data.description}</p>
							{project.data.highlight && (
								<p class="text-global-text mb-3 text-sm">
									<span class="text-accent">→ </span>
									{project.data.highlight}
								</p>
							)}
							{project.data.stack.length > 0 && (
								<ul class="flex flex-wrap gap-1.5" role="list">
									{project.data.stack.map((tech) => (
										<li class="bg-accent/10 text-muted rounded px-1.5 py-0.5 text-xs">{tech}</li>
									))}
								</ul>
							)}
						</li>
					))}
				</ul>
			</section>
		))
	}
	{projects.length === 0 && <p>还没有项目,稍等。</p>}
</PageLayout>
